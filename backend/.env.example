# Copy to `.env` and configure. Do not commit `.env`.

PORT=3000
NODE_ENV=development

# JWT for main app auth
JWT_SECRET=change-me

# PostgreSQL (RDS) — e.g. your-instance.xxx.ap-south-1.rds.amazonaws.com
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_SSL=true
# Optional: default schema for app tables (search_path). Leave unset for public-only / transport-only DBs.
# DB_SCHEMA=schoolpulse
# Required for RDS when DB_SSL=true (download global-bundle.pem from AWS RDS SSL docs)
# DB_SSL_CA_PATH=certs/rds-global-bundle.pem

# Transport module — shared secret for Transport admin UI (header X-Transport-Admin-Secret).
# Must match the frontend Vite variable VITE_TRANSPORT_ADMIN_SECRET.
# Alternative: omit this and use a logged-in school admin or superadmin JWT instead.
TRANSPORT_ADMIN_SECRET=change-me-to-match-vite
# RFID scanner devices (ESP32) should send this header:
# X-Transport-Scanner-Secret: <value>
TRANSPORT_SCANNER_SECRET=
# SQL: run backend/sql/2026-04-06-transport_drivers.sql then backend/sql/2026-04-08-transport_fleet.sql (buses, routes, stops, driver assignments).

# Amazon Location — set when using map proxy (VITE_AWS_LOCATION_USE_MAP_PROXY in Transport/.env).
# Same API key value as VITE_AWS_LOCATION_API_KEY; server fetches tiles (helps avoid browser referrer 403).
# Also used for Places autocomplete / GetPlace in Transport admin (GET /api/transport/places/*).
# AWS_LOCATION_API_KEY=
# Optional: Places Autocomplete bias [lng, lat] (default: Hyderabad).
# AWS_PLACES_BIAS_LNG=78.4747
# AWS_PLACES_BIAS_LAT=17.3850
# AWS_PLACES_REGION=ap-south-1
# Optional: Autocomplete country filter (comma-separated ISO codes, e.g. IND or IN,USA). Default IND if unset.
# Set to empty to allow all countries: AWS_PLACES_INCLUDE_COUNTRIES=
# AWS_PLACES_INCLUDE_COUNTRIES=IND

# Amazon Location Routes (road-snapped polylines for map preview)
# Uses Routes V2 endpoint: POST https://routes.geo.${AWS_ROUTES_REGION}/routes?key=AWS_LOCATION_API_KEY
# If unset, falls back to AWS_PLACES_REGION / AWS_REGION / ap-south-1
# AWS_ROUTES_REGION=ap-south-1

# Amazon Location Trackers (live bus tracking) — requires AWS credentials (SigV4), NOT API keys.
# Set these for GET/POST /api/transport/tracker/*
# AWS_TRACKER_NAME=campos-ai-transport
# AWS_TRACKER_REGION=ap-south-1
#
# Provide AWS credentials in your deployment (recommended: IAM role).
# Optional: use dedicated credentials just for Location tracker calls (useful if tracker is in a different AWS account):
# AWS_TRACKER_ACCESS_KEY_ID=
# AWS_TRACKER_SECRET_ACCESS_KEY=
# AWS_TRACKER_SESSION_TOKEN=   # optional (if using temporary creds)
#
# Or fall back to general AWS env vars:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # optional (if using temporary creds)
