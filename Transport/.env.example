# Copy to `Transport/.env`. Restart Vite after changes.
# Integrated with ConventPulse later — keep transport-specific keys here until then.

# Optional override (otherwise uses root `VITE_API_URL` from project `.env`)
# VITE_API_URL=http://localhost:3000/api
# Sandbox EC2 example (HTTP):
# VITE_API_URL=http://13.203.78.56:3000/api

# Shared with backend `TRANSPORT_ADMIN_SECRET`
VITE_TRANSPORT_ADMIN_SECRET=

# Amazon Location Service — MapLibre map (see Transport/components/AwsLocationMap.tsx)
# VITE_AWS_LOCATION_MAP_ARN=arn:aws:geo:REGION:account:map/MapName
# Or: VITE_AWS_LOCATION_REGION + VITE_AWS_LOCATION_MAP_NAME
# Auth: set VITE_AWS_LOCATION_API_KEY (geo-maps GetTile on provider/default), OR Cognito pool.
# Default is Maps API v2 style URL (/v2/styles/Standard/descriptor). Legacy v0 map name path is for Cognito/IAM.
# VITE_AWS_LOCATION_MAPS_API_VERSION=v2
# VITE_AWS_LOCATION_MAP_STYLE=Standard
# VITE_AWS_LOCATION_API_KEY=
# false = MapLibre calls maps.geo directly with VITE_AWS_LOCATION_API_KEY (typical for Keys v2). true = proxy via backend (needs backend/.env AWS_LOCATION_API_KEY; use if key has referrer restrictions).
# VITE_AWS_LOCATION_USE_MAP_PROXY=false
# VITE_AWS_COGNITO_IDENTITY_POOL_ID=
